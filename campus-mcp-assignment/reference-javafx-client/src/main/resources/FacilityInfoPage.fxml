<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<VBox alignment="TOP_CENTER"
      spacing="20.0"
      prefWidth="800.0"
      prefHeight="600.0"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.campus.client.ui.FacilityInfoController">

    <padding>
        <Insets top="25.0" right="30.0" bottom="25.0" left="30.0"/>
    </padding>

    <children>
        <HBox alignment = "CENTER_LEFT">
            <children>
                <Button fx:id="facilityInfoBackButton"
                        text="Back"
                        onAction="#facilityInfoBackButtonClicked"/>
            </children>
        </HBox>

        <Label text="Facility Info">
            <font>
                <Font size="24.0"/>
            </font>
        </Label>

        <HBox alignment="CENTER" spacing="15.0">
            <children>
                <Label text="Facility:"/>

                <ChoiceBox fx:id="chooseFacilityDropbox"
                           prefWidth="220.0"/>

                <Button fx:id="facilityInfoConfirmButton"
                        text="Confirm"
                        onAction="#facilityInfoConfirmButtonClicked"/>
            </children>
        </HBox>

        <TextArea fx:id="facilityInfoTextArea"
                  prefWidth="620.0"
                  prefHeight="330.0"
                  editable="false"
                  wrapText="true"
                  text="Choose a facility and click Confirm."/>
    </children>
</VBox>